{
  "expo": {
    "name": "CarMarket",
    "slug": "frontend",
    "jsEngine": "hermes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/image/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/image/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/3e7e4a34-e5dd-40c5-ba36-856a01210806"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yousseflab.carmarket",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera for video calls.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for audio calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/image/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yousseflab.carmarket",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/image/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "@maplibre/maplibre-react-native",
      "expo-font",
      "expo-localization",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f35b6969-80f3-44fc-a7c6-448473e6915a"
      }
    },
    "owner": "youssefdev54"
  }
}
