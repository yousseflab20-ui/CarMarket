{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/image/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/image/image-CreeCompt.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youssef.carmarket"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/image/image-CreeCompt.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.youssef.carmarket"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/image/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f35b6969-80f3-44fc-a7c6-448473e6915a"
      }
    },
    "owner": "youssefdev54"
  }
}
